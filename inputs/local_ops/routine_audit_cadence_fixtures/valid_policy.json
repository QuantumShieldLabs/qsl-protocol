  "depth_levels": [
    {
      "id": "quick_read_only",
      "title": "Quick read-only audit",
      "purpose": "Fast posture check before closeout or after low-risk governance work",
      "boundary": "no durable report, no broad code scan"
    },
    {
      "id": "standard_read_only",
      "title": "Standard read-only audit",
      "purpose": "Routine cadence pass for thresholds and public-claim preparation",
      "boundary": "bounded heavy checks, findings table, no durable report"
    },
    {
      "id": "deep_read_only_microscope",
      "title": "Deep read-only microscope audit",
      "purpose": "Higher confidence local review before external review or after major lane clusters",
      "boundary": "broader source and formal review, still read-only with no durable report"
    },
    {
      "id": "targeted_code_crypto_microscope",
      "title": "Targeted code crypto microscope audit",
      "purpose": "Focused security audit after protocol, crypto, runtime, or dependency risk",
      "boundary": "narrow component, high evidence density, no implementation and no durable report"
