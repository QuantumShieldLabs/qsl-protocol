  "severity_taxonomy": [
    {
      "id": "CRITICAL",
      "description": "Active safety, security, or truthful-governance issue requiring triage before continuation.",
      "stop_or_escalate": true,
      "queue_action": "STOP_AND_TRIAGE"
    },
    {
      "id": "HIGH",
      "description": "Serious security, correctness, backup, CI, or claim-boundary risk needing near-term queue action.",
      "stop_or_escalate": true,
      "queue_action": "STOP_AND_TRIAGE"
    },
    {
      "id": "MEDIUM",
      "description": "Material risk or evidence gap that should become a candidate lane.",
      "stop_or_escalate": false,
      "queue_action": "PROPOSE_BACKLOG"
    },
    {
      "id": "LOW",
      "description": "Improvement or cleanup with limited immediate risk.",
      "stop_or_escalate": false,
      "queue_action": "PROPOSE_BACKLOG"
    },
    {
      "id": "INFO",
      "description": "Neutral evidence or context.",
      "stop_or_escalate": false,
      "queue_action": "RECORD_ONLY"
    },
    {
      "id": "EVIDENCE_INCOMPLETE",
      "description": "Insufficient proof; no negative claim may be made.",
      "stop_or_escalate": false,
      "queue_action": "PROPOSE_BACKLOG"
    },
    {
      "id": "CLAIM_BOUNDARY",
      "description": "Public-surface risk where evidence does not support stronger claims.",
      "stop_or_escalate": false,
      "queue_action": "CLAIM_BOUNDARY_REVIEW"
    },
    {
      "id": "BACKLOG_CANDIDATE",
      "description": "Useful future work that is not urgent.",
      "stop_or_escalate": false,
      "queue_action": "PROPOSE_BACKLOG"
    }
  ],
  "queue_insertion_policy": {
    "auto_promote_ready": false,
    "max_ready_candidates": 0,
    "allowed_candidate_statuses": ["BACKLOG_CANDIDATE"],
    "one_ready_required": true,
