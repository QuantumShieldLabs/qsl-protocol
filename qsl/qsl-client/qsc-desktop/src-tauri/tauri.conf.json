{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QSC Desktop Prototype",
  "version": "0.1.0",
  "identifier": "labs.quantumshield.qscdesktopprototype",
  "build": {
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "QSC Desktop Prototype",
        "width": 1500,
        "height": 980,
        "minWidth": 1120,
        "minHeight": 780,
        "resizable": true
      }
    ],
    "withGlobalTauri": false,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "appimage",
      "app"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "resources": [
      "resources/bin/qsc"
    ]
  }
}
